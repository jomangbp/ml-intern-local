# ── OpenAI via Codex Subscription ────────────────────────────────────────────
# GPT-5.x models are accessed through a ChatGPT Pro/Plus Codex subscription.
# No OPENAI_API_KEY needed — authenticate via the Codex CLI:
#
#   1. Install Codex CLI:  npm install -g @openai/codex
#   2. Log in:             codex login --device-auth
#   3. Done — ml-intern auto-detects the token at ~/.config/codex/auth.json
#
# Alternatively, set CODEX_AUTH_TOKEN manually:
# CODEX_AUTH_TOKEN=

# ── HF Token Plan Providers ────────────────────────────────────────────────
# MiniMax Token Plan: https://platform.minimax.io/user-center/basic-information/interface-key
#   Route: MiniMaxAI/MiniMax-M2.7, MiniMaxAI/MiniMax-M2.5 → api.minimax.io/anthropic
MINIMAX_API_KEY=your_minimax_api_key_here

# Z.ai dev platform: https://docs.z.ai/devpack/faq
#   Route: zai-org/GLM-5.1, zai-org/GLM-4.6 → api.z.ai/anthropic/v1
ZAI_API_KEY=your_zai_api_key_here

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Required for dataset/hub access. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ── Anthropic (for Claude models) ─────────────────────────────────────────────
# Only needed for models prefixed with anthropic/
# Get one at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_ALLOWED_CHAT_IDS=your_numeric_chat_id_here
# TELEGRAM_EXECUTION_MODE=local
